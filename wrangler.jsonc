{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tymomoc2",
  "main": "src/index.js",
  "compatibility_date": "2026-07-19",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tymomoc-db",
      "database_id": "d1d43df1-0d3a-4e39-ba38-55d885fa9ed6",
      "migrations_dir": "migrations"
    }
  ]
}
